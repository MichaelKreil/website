{
  "name": "michael-kreil.de",
  "version": "1.1.0",
  "description": "",
  "scripts": {
    "build": "tsx src/build.ts",
    "check": "npm run format && npm run lint && npm run test",
    "dev": "tsx src/dev.ts",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish": "npm run build && ./upload.sh",
    "upgrade": "ncu -u && rm -f package-lock.json; rm -rf node_modules; npm install",
    "upload": "./upload.sh"
  },
  "author": "Michael Kreil",
  "license": "MIT",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@versatiles/release-tool": "^2.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "npm-check-updates": "^22.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "work-faster": "^2.5.7"
  }
}
